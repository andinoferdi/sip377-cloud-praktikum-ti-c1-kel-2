{
  "info": {
    "_postman_id": "accel-modul-2",
    "name": "Modul 2: Accelerometer API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Send Accelerometer Batch",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "text/plain;charset=UTF-8"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"dev-001\",\n  \"ts\": \"{{current_timestamp}}\",\n  \"samples\": [\n    {\n      \"t\": \"2026-02-18T10:15:29.100Z\",\n      \"x\": 0.12,\n      \"y\": 0.01,\n      \"z\": 9.70\n    },\n    {\n      \"t\": \"2026-02-18T10:15:29.300Z\",\n      \"x\": 0.15,\n      \"y\": 0.02,\n      \"z\": 9.68\n    },\n    {\n      \"t\": \"2026-02-18T10:15:29.500Z\",\n      \"x\": 0.18,\n      \"y\": 0.03,\n      \"z\": 9.65\n    }\n  ]\n}\n"
        },
        "url": {
          "raw": "{{BASE_URL}}/macros/d/{{DEPLOYMENT_ID}}/usercallback?path=telemetry/accel",
          "protocol": "https",
          "host": [
            "{{BASE_URL}}\",\n    \"macros\",\n    \"d\",\n    \"{{DEPLOYMENT_ID}}\",\n    \"usercallback\"\n          ],
          "query": [
            {
              "key": "path",
              "value": "telemetry/accel"
            }
          ]
        },
        "description": "Send batch of accelerometer samples to backend\n\nExpected response:\n{\n  \"ok\": true,\n  \"data\": {\n    \"accepted\": 3\n  }\n}"
      }
    },
    {
      "name": "2. Get Latest Accelerometer Data",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/macros/d/{{DEPLOYMENT_ID}}/usercallback?path=telemetry/accel/latest&device_id=dev-001",
          "protocol": "https",
          "host": [
            "{{BASE_URL}}\",\n    \"macros\",\n    \"d\",\n    \"{{DEPLOYMENT_ID}}\",\n    \"usercallback\"\n          ],
          "query": [
            {
              "key": "path\",\n              \"value\": \"telemetry/accel/latest\"\n            },\n            {\n              \"key\": \"device_id\",\n              \"value\": \"dev-001\"\n            }\n          ]
        },
        "description": "Get latest accelerometer data for a device\n\nExpected response:\n{\n  \"ok\": true,\n  \"data\": {\n    \"t\": \"2026-02-18T10:15:29.300Z\",\n    \"x\": 0.15,\n    \"y\": 0.02,\n    \"z\": 9.68\n  }\n}"
      }
    },
    {
      "name": "3. Send Multiple Devices",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "text/plain;charset=UTF-8"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"dev-002\",\n  \"ts\": \"{{current_timestamp}}\",\n  \"samples\": [\n    {\n      \"t\": \"2026-02-18T10:20:00.000Z\",\n      \"x\": 0.50,\n      \"y\": -0.20,\n      \"z\": 9.81\n    },\n    {\n      \"t\": \"2026-02-18T10:20:00.200Z\",\n      \"x\": 0.55,\n      \"y\": -0.25,\n      \"z\": 9.79\n    }\n  ]\n}\n"
        },
        "url": {
          "raw": "{{BASE_URL}}/macros/d/{{DEPLOYMENT_ID}}/usercallback?path=telemetry/accel",
          "protocol": "https",
          "host": [
            "{{BASE_URL}}\",\n    \"macros\",\n    \"d\",\n    \"{{DEPLOYMENT_ID}}\",\n    \"usercallback\"\n          ],
          "query": [
            {
              "key": "path",
              "value": "telemetry/accel"
            }
          ]
        },
        "description": "Submit from different device ID (dev-002)"
      }
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "script.google.com",
      "type": "string"
    },
    {
      "key": "DEPLOYMENT_ID",
      "value": "your_deployment_id_here",
      "type": "string"
    },
    {
      "key": "current_timestamp",
      "value": "2026-02-18T10:15:30Z",
      "type": "string"
    }
  ]
}
